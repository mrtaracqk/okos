{
  "name": "okos-telegram",
  "version": "2.3.13",
  "description": "Okos - AI Assistant Telegram Bot using LangGraph and Cloud LLM Providers",
  "author": {
    "name": "Johnny Bui",
    "url": "https://github.com/johnnybui"
  },
  "main": "dist/app.js",
  "scripts": {
    "build": "bun build ./src/app.ts --outdir=dist --target bun",
    "dev": "bun --watch src/app.ts",
    "studio": "langgraphjs dev",
    "start": "bun dist/app.js",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "up:dev": "docker compose -f ./docker-compose.dev.yml up -d",
    "down:dev": "docker compose -f ./docker-compose.dev.yml down",
    "build:cloud": "docker compose -f ./docker-compose-cloud.yml build",
    "up:cloud": "docker compose -f ./docker-compose-cloud.yml up -d",
    "down:cloud": "docker compose -f ./docker-compose-cloud.yml down"
  },
  "dependencies": {
    "@arizeai/openinference-core": "^2.0.5",
    "@arizeai/openinference-instrumentation-langchain": "^4.0.6",
    "@arizeai/openinference-semantic-conventions": "^2.1.7",
    "@arizeai/phoenix-otel": "^0.4.2",
    "@elysiajs/html": "^1.2.0",
    "@langchain/core": "^1.1.32",
    "@langchain/google-genai": "^2.1.25",
    "@langchain/groq": "^1.1.5",
    "@langchain/langgraph": "^1.2.2",
    "@langchain/openai": "^1.2.13",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@opentelemetry/api": "^1.9.0",
    "bullmq": "^5.41.7",
    "date-fns": "^4.1.0",
    "duck-duck-scrape": "^2.2.6",
    "elysia": "^1.2.10",
    "groq-sdk": "^0.9.1",
    "ioredis": "^5.3.2",
    "node-telegram-bot-api": "^0.64.0"
  },
  "devDependencies": {
    "@langchain/langgraph-cli": "^1.1.15",
    "@types/node-telegram-bot-api": "^0.64.1",
    "bun-types": "^1.2.0"
  }
}
